{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$ref": "#/definitions/ListPositionsResponse",
    "definitions": {
        "ListPositionsResponse": {
            "properties": {
                "positions": {
                    "items": {
                        "$ref": "#/definitions/upp.v1.Position"
                    },
                    "type": "array"
                },
                "summary": {
                    "$ref": "#/definitions/upp.v1.PortfolioSummary",
                    "additionalProperties": true,
                    "description": "Aggregated summary for this result set"
                },
                "pagination": {
                    "$ref": "#/definitions/upp.v1.PaginationResponse",
                    "additionalProperties": true
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "List Positions Response"
        },
        "upp.v1.PaginationResponse": {
            "properties": {
                "cursor": {
                    "type": "string",
                    "description": "Cursor for next page (empty if no more)"
                },
                "has_more": {
                    "type": "boolean",
                    "description": "Whether more results exist"
                },
                "total": {
                    "type": "integer",
                    "description": "Total count (if available, -1 if unknown)"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "Pagination Response",
            "description": "Cursor-based pagination response."
        },
        "upp.v1.PortfolioSummary": {
            "properties": {
                "total_invested": {
                    "type": "string",
                    "description": "Sum of all cost bases"
                },
                "total_current_value": {
                    "type": "string",
                    "description": "Sum of all current values"
                },
                "total_unrealized_pnl": {
                    "type": "string",
                    "description": "Sum of all unrealized P\u0026L"
                },
                "total_realized_pnl": {
                    "type": "string",
                    "description": "Sum of all realized P\u0026L"
                },
                "open_position_count": {
                    "type": "integer",
                    "description": "Number of open positions"
                },
                "market_count": {
                    "type": "integer",
                    "description": "Unique markets with positions"
                },
                "provider_summaries": {
                    "items": {
                        "$ref": "#/definitions/upp.v1.ProviderSummary"
                    },
                    "type": "array",
                    "description": "Per-provider breakdown"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Portfolio Summary ───────────────────────────────────────",
            "description": "─── Portfolio Summary ───────────────────────────────────────  Aggregated portfolio metrics across positions."
        },
        "upp.v1.Position": {
            "properties": {
                "market_id": {
                    "$ref": "#/definitions/upp.v1.UniversalMarketId",
                    "additionalProperties": true
                },
                "outcome_id": {
                    "type": "string",
                    "description": "Which outcome (e.g. \"yes\")"
                },
                "quantity": {
                    "type": "string",
                    "description": "Number of contracts held"
                },
                "average_entry_price": {
                    "type": "string",
                    "description": "Weighted average entry price"
                },
                "current_price": {
                    "type": "string",
                    "description": "Current market price for this outcome"
                },
                "cost_basis": {
                    "type": "string",
                    "description": "P\u0026L  Total cost paid"
                },
                "current_value": {
                    "type": "string",
                    "description": "quantity * current_price"
                },
                "unrealized_pnl": {
                    "type": "string",
                    "description": "current_value - cost_basis"
                },
                "realized_pnl": {
                    "type": "string",
                    "description": "Profit from closed portions"
                },
                "status": {
                    "enum": [
                        "POSITION_STATUS_UNSPECIFIED",
                        0,
                        "POSITION_STATUS_OPEN",
                        1,
                        "POSITION_STATUS_CLOSED",
                        2,
                        "POSITION_STATUS_SETTLED",
                        3,
                        "POSITION_STATUS_EXPIRED",
                        4
                    ],
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "integer"
                        }
                    ],
                    "title": "Position Status"
                },
                "opened_at": {
                    "$ref": "#/definitions/upp.v1.Timestamp",
                    "additionalProperties": true,
                    "description": "When first contract was acquired"
                },
                "updated_at": {
                    "$ref": "#/definitions/upp.v1.Timestamp",
                    "additionalProperties": true,
                    "description": "Last change"
                },
                "market_title": {
                    "type": "string",
                    "description": "Market context (denormalized for convenience)"
                },
                "market_status": {
                    "enum": [
                        "MARKET_STATUS_UNSPECIFIED",
                        0,
                        "MARKET_STATUS_PENDING",
                        1,
                        "MARKET_STATUS_OPEN",
                        2,
                        "MARKET_STATUS_HALTED",
                        3,
                        "MARKET_STATUS_CLOSED",
                        4,
                        "MARKET_STATUS_RESOLVED",
                        5,
                        "MARKET_STATUS_DISPUTED",
                        6,
                        "MARKET_STATUS_VOIDED",
                        7
                    ],
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "integer"
                        }
                    ],
                    "title": "Market Status"
                },
                "provider_metadata": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Position ────────────────────────────────────────────────",
            "description": "─── Position ────────────────────────────────────────────────  A user's holding in a specific market outcome."
        },
        "upp.v1.ProviderSummary": {
            "properties": {
                "provider": {
                    "type": "string"
                },
                "invested": {
                    "type": "string"
                },
                "current_value": {
                    "type": "string"
                },
                "unrealized_pnl": {
                    "type": "string"
                },
                "realized_pnl": {
                    "type": "string"
                },
                "position_count": {
                    "type": "integer"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "Provider Summary"
        },
        "upp.v1.Timestamp": {
            "properties": {
                "seconds": {
                    "type": "string",
                    "description": "Unix epoch seconds"
                },
                "nanos": {
                    "type": "integer",
                    "description": "Sub-second nanoseconds [0, 999999999]"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Temporal ────────────────────────────────────────────────",
            "description": "─── Temporal ────────────────────────────────────────────────  High-precision timestamp for trading events. Always UTC. Nanosecond precision for orderbook/trade events."
        },
        "upp.v1.UniversalMarketId": {
            "properties": {
                "provider": {
                    "type": "string",
                    "description": "Provider domain, e.g. \"kalshi.com\""
                },
                "native_id": {
                    "type": "string",
                    "description": "Provider's native market ID"
                },
                "full_id": {
                    "type": "string",
                    "description": "Computed: \"upp:{provider}:{native_id}\""
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Identity ────────────────────────────────────────────────",
            "description": "─── Identity ────────────────────────────────────────────────  Universal Market Identifier. Format: \"upp:{provider}:{native_id}\" Enables cross-provider market matching and portfolio aggregation."
        }
    }
}