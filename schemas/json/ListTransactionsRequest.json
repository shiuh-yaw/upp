            "additionalProperties": true,
            "type": "object",
            "title": "List Transactions Request"
        },
        "upp.v1.PaginationRequest": {
            "properties": {
                "limit": {
                    "type": "integer",
                    "description": "Max items per page [1, 1000], default 50"
                },
                "cursor": {
                    "type": "string",
                    "description": "Opaque cursor from previous response"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Pagination ──────────────────────────────────────────────",
            "description": "─── Pagination ──────────────────────────────────────────────  Cursor-based pagination request. Cursor-based (not offset-based) for consistency under real-time inserts."
        },
        "upp.v1.TimeRange": {
            "properties": {
                "start": {
                    "$ref": "#/definitions/upp.v1.Timestamp",
                    "additionalProperties": true
                },
                "end": {
