{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$ref": "#/definitions/SearchMarketsResponse",
    "definitions": {
        "SearchMarketsResponse": {
            "properties": {
                "markets": {
                    "items": {
                        "$ref": "#/definitions/upp.v1.Market"
                    },
                    "type": "array"
                },
                "pagination": {
                    "$ref": "#/definitions/upp.v1.PaginationResponse",
                    "additionalProperties": true
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "Search Markets Response"
        },
        "upp.v1.Event": {
            "properties": {
                "id": {
                    "type": "string",
                    "description": "Provider's event identifier"
                },
                "title": {
                    "type": "string",
                    "description": "Human-readable title, e.g. \"Will Bitcoin reach $100K?\""
                },
                "description": {
                    "type": "string",
                    "description": "Detailed resolution criteria"
                },
                "category": {
                    "type": "string",
                    "description": "Primary category (crypto, politics, sports, etc.)"
                },
                "tags": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array",
                    "description": "Searchable tags"
                },
                "image_url": {
                    "type": "string",
                    "description": "Event image/icon URL"
                },
                "series_id": {
                    "type": "string",
                    "description": "For grouped events (e.g. Kalshi \"series\")  Parent series/group identifier"
                },
                "series_title": {
                    "type": "string",
                    "description": "Series name"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "Event",
            "description": "The event being predicted on."
        },
        "upp.v1.Market": {
            "properties": {
                "id": {
                    "$ref": "#/definitions/upp.v1.UniversalMarketId",
                    "additionalProperties": true,
                    "description": "Universal ID: upp:{provider}:{native_id}"
                },
                "event": {
                    "$ref": "#/definitions/upp.v1.Event",
                    "additionalProperties": true,
                    "description": "The event being predicted"
                },
                "market_type": {
                    "enum": [
                        "MARKET_TYPE_UNSPECIFIED",
                        0,
                        "MARKET_TYPE_BINARY",
                        1,
                        "MARKET_TYPE_CATEGORICAL",
                        2,
                        "MARKET_TYPE_SCALAR",
                        3
                    ],
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "integer"
                        }
                    ],
                    "title": "─── Market Types ────────────────────────────────────────────",
                    "description": "─── Market Types ────────────────────────────────────────────"
                },
                "outcomes": {
                    "items": {
                        "$ref": "#/definitions/upp.v1.Outcome"
                    },
                    "type": "array",
                    "description": "Possible outcomes (2 for binary, N for categorical)"
                },
                "pricing": {
                    "$ref": "#/definitions/upp.v1.MarketPricing",
                    "additionalProperties": true,
                    "description": "Current price/probability data"
                },
                "volume": {
                    "$ref": "#/definitions/upp.v1.MarketVolume",
                    "additionalProperties": true,
                    "description": "Trading volume metrics"
                },
                "lifecycle": {
                    "$ref": "#/definitions/upp.v1.MarketLifecycle",
                    "additionalProperties": true,
                    "description": "Status and key dates"
                },
                "rules": {
                    "$ref": "#/definitions/upp.v1.MarketRules",
                    "additionalProperties": true,
                    "description": "Trading rules and constraints"
                },
                "regulatory": {
                    "$ref": "#/definitions/upp.v1.MarketRegulatory",
                    "additionalProperties": true,
                    "description": "Compliance metadata"
                },
                "provider_metadata": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "Provider-specific metadata (passthrough for provider extensions)"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Market ──────────────────────────────────────────────────",
            "description": "─── Market ──────────────────────────────────────────────────  A prediction market — the core tradeable entity. Equivalent to UCP's \"Product\" in commerce."
        },
        "upp.v1.MarketLifecycle": {
            "properties": {
                "status": {
                    "enum": [
                        "MARKET_STATUS_UNSPECIFIED",
                        0,
                        "MARKET_STATUS_PENDING",
                        1,
                        "MARKET_STATUS_OPEN",
                        2,
                        "MARKET_STATUS_HALTED",
                        3,
                        "MARKET_STATUS_CLOSED",
                        4,
                        "MARKET_STATUS_RESOLVED",
                        5,
                        "MARKET_STATUS_DISPUTED",
                        6,
                        "MARKET_STATUS_VOIDED",
                        7
                    ],
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "integer"
                        }
                    ],
                    "title": "Market Status"
                },
                "created_at": {
                    "$ref": "#/definitions/upp.v1.Timestamp",
                    "additionalProperties": true,
                    "description": "When market was created"
                },
                "opens_at": {
                    "$ref": "#/definitions/upp.v1.Timestamp",
                    "additionalProperties": true,
                    "description": "When trading opens (if scheduled)"
                },
                "closes_at": {
                    "$ref": "#/definitions/upp.v1.Timestamp",
                    "additionalProperties": true,
                    "description": "When trading closes"
                },
                "resolved_at": {
                    "$ref": "#/definitions/upp.v1.Timestamp",
                    "additionalProperties": true,
                    "description": "When market was resolved (if resolved)"
                },
                "expires_at": {
                    "$ref": "#/definitions/upp.v1.Timestamp",
                    "additionalProperties": true,
                    "description": "Hard expiry date"
                },
                "resolution_source": {
                    "type": "string",
                    "description": "Description of resolution mechanism"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Lifecycle ───────────────────────────────────────────────",
            "description": "─── Lifecycle ───────────────────────────────────────────────  Market status and key dates."
        },
        "upp.v1.MarketPricing": {
            "properties": {
                "last_price": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "Last traded prices per outcome  outcome_id -\u003e price string"
                },
                "best_bid": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "Best bid/ask per outcome  outcome_id -\u003e best bid price"
                },
                "best_ask": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "outcome_id -\u003e best ask price"
                },
                "mid_price": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "Mid price (average of best bid and ask)"
                },
                "spread": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "Spread  outcome_id -\u003e bid-ask spread"
                },
                "tick_size": {
                    "type": "string",
                    "description": "Minimum price increment, e.g. \"0.01\""
                },
                "currency": {
                    "type": "string",
                    "description": "Settlement currency (USD, USDC, etc.)"
                },
                "min_order_size": {
                    "type": "integer",
                    "description": "Minimum contracts per order"
                },
                "max_order_size": {
                    "type": "integer",
                    "description": "Maximum contracts per order (0 = unlimited)"
                },
                "updated_at": {
                    "$ref": "#/definitions/upp.v1.Timestamp",
                    "additionalProperties": true,
                    "description": "When pricing was last updated"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Pricing ─────────────────────────────────────────────────",
            "description": "─── Pricing ─────────────────────────────────────────────────  Current pricing snapshot for a market."
        },
        "upp.v1.MarketRegulatory": {
            "properties": {
                "jurisdiction": {
                    "type": "string",
                    "description": "Primary jurisdiction (ISO 3166-1 alpha-2)"
                },
                "compliant": {
                    "type": "boolean",
                    "description": "Provider self-attestation of compliance"
                },
                "eligible_regions": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array",
                    "description": "Regions allowed to trade"
                },
                "restricted_regions": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array",
                    "description": "Regions explicitly blocked"
                },
                "regulator": {
                    "type": "string",
                    "description": "Regulatory body (e.g. \"CFTC\", \"none\")"
                },
                "license_type": {
                    "type": "string",
                    "description": "License type (e.g. \"DCM\", \"none\")"
                },
                "contract_type": {
                    "type": "string",
                    "description": "Legal classification (event_contract, binary_option, swap)"
                },
                "required_kyc": {
                    "enum": [
                        "KYC_LEVEL_UNSPECIFIED",
                        0,
                        "KYC_LEVEL_NONE",
                        1,
                        "KYC_LEVEL_BASIC",
                        2,
                        "KYC_LEVEL_ENHANCED",
                        3,
                        "KYC_LEVEL_INSTITUTIONAL",
                        4
                    ],
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "integer"
                        }
                    ],
                    "title": "Kyc Level"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Regulatory ──────────────────────────────────────────────",
            "description": "─── Regulatory ──────────────────────────────────────────────  Compliance and regulatory metadata. Critical for multi-jurisdiction prediction market access."
        },
        "upp.v1.MarketRules": {
            "properties": {
                "allowed_order_types": {
                    "items": {
                        "enum": [
                            "ORDER_TYPE_UNSPECIFIED",
                            0,
                            "ORDER_TYPE_LIMIT",
                            1,
                            "ORDER_TYPE_MARKET",
                            2
                        ]
                    },
                    "type": "array",
                    "title": "Order Type",
                    "description": "Order types supported by the market."
                },
                "allowed_tif": {
                    "items": {
                        "enum": [
                            "TIME_IN_FORCE_UNSPECIFIED",
                            0,
                            "TIME_IN_FORCE_GTC",
                            1,
                            "TIME_IN_FORCE_GTD",
                            2,
                            "TIME_IN_FORCE_FOK",
                            3,
                            "TIME_IN_FORCE_IOC",
                            4
                        ]
                    },
                    "type": "array",
                    "title": "Time In Force",
                    "description": "Time-in-force policies."
                },
                "allows_short_selling": {
                    "type": "boolean",
                    "description": "Can sell without holding"
                },
                "allows_partial_fill": {
                    "type": "boolean",
                    "description": "Can orders partially fill"
                },
                "maker_fee_rate": {
                    "type": "string",
                    "description": "Maker fee as decimal, e.g. \"0.00\""
                },
                "taker_fee_rate": {
                    "type": "string",
                    "description": "Taker fee as decimal, e.g. \"0.02\""
                },
                "max_position_size": {
                    "type": "integer",
                    "description": "Position limits  Max contracts per user (0 = unlimited)"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Rules ───────────────────────────────────────────────────",
            "description": "─── Rules ───────────────────────────────────────────────────  Trading rules and constraints for a market."
        },
        "upp.v1.MarketVolume": {
            "properties": {
                "total_volume": {
                    "type": "string",
                    "description": "All-time volume in settlement currency"
                },
                "volume_24h": {
                    "type": "string",
                    "description": "Last 24h volume"
                },
                "volume_7d": {
                    "type": "string",
                    "description": "Last 7d volume"
                },
                "open_interest": {
                    "type": "string",
                    "description": "Currently outstanding contracts"
                },
                "num_traders": {
                    "type": "integer",
                    "description": "Unique traders (if available)"
                },
                "updated_at": {
                    "$ref": "#/definitions/upp.v1.Timestamp",
                    "additionalProperties": true
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Volume ──────────────────────────────────────────────────",
            "description": "─── Volume ──────────────────────────────────────────────────  Trading activity metrics."
        },
        "upp.v1.Outcome": {
            "properties": {
                "id": {
                    "type": "string",
                    "description": "Outcome identifier (e.g. \"yes\", \"no\", \"candidate_a\")"
                },
                "label": {
                    "type": "string",
                    "description": "Human-readable label"
                },
                "token_id": {
                    "type": "string",
                    "description": "On-chain token ID (if applicable, e.g. Polymarket CTF)"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "Outcome",
            "description": "A possible outcome of the market."
        },
        "upp.v1.PaginationResponse": {
            "properties": {
                "cursor": {
                    "type": "string",
                    "description": "Cursor for next page (empty if no more)"
                },
                "has_more": {
                    "type": "boolean",
                    "description": "Whether more results exist"
                },
                "total": {
                    "type": "integer",
                    "description": "Total count (if available, -1 if unknown)"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "Pagination Response",
            "description": "Cursor-based pagination response."
        },
        "upp.v1.Timestamp": {
            "properties": {
                "seconds": {
                    "type": "string",
                    "description": "Unix epoch seconds"
                },
                "nanos": {
                    "type": "integer",
                    "description": "Sub-second nanoseconds [0, 999999999]"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Temporal ────────────────────────────────────────────────",
            "description": "─── Temporal ────────────────────────────────────────────────  High-precision timestamp for trading events. Always UTC. Nanosecond precision for orderbook/trade events."
        },
        "upp.v1.UniversalMarketId": {
            "properties": {
                "provider": {
                    "type": "string",
                    "description": "Provider domain, e.g. \"kalshi.com\""
                },
                "native_id": {
                    "type": "string",
                    "description": "Provider's native market ID"
                },
                "full_id": {
                    "type": "string",
                    "description": "Computed: \"upp:{provider}:{native_id}\""
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Identity ────────────────────────────────────────────────",
            "description": "─── Identity ────────────────────────────────────────────────  Universal Market Identifier. Format: \"upp:{provider}:{native_id}\" Enables cross-provider market matching and portfolio aggregation."
        }
    }
}