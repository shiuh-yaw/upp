{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$ref": "#/definitions/Error",
    "definitions": {
        "Error": {
            "properties": {
                "code": {
                    "enum": [
                        "ERROR_CODE_UNSPECIFIED",
                        0,
                        "ERROR_CODE_INVALID_ARGUMENT",
                        1,
                        "ERROR_CODE_NOT_FOUND",
                        2,
                        "ERROR_CODE_ALREADY_EXISTS",
                        3,
                        "ERROR_CODE_PERMISSION_DENIED",
                        4,
                        "ERROR_CODE_UNAUTHENTICATED",
                        5,
                        "ERROR_CODE_RATE_LIMITED",
                        6,
                        "ERROR_CODE_INSUFFICIENT_FUNDS",
                        7,
                        "ERROR_CODE_MARKET_CLOSED",
                        8,
                        "ERROR_CODE_ORDER_REJECTED",
                        9,
                        "ERROR_CODE_REGION_RESTRICTED",
                        10,
                        "ERROR_CODE_INTERNAL",
                        50,
                        "ERROR_CODE_UNAVAILABLE",
                        51,
                        "ERROR_CODE_TIMEOUT",
                        52,
                        "ERROR_CODE_PROVIDER_ERROR",
                        53
                    ],
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "integer"
                        }
                    ],
                    "title": "Error Code",
                    "description": "Standardized error codes across all providers."
                },
                "message": {
                    "type": "string",
                    "description": "Human-readable description"
                },
                "provider": {
                    "type": "string",
                    "description": "Which provider originated the error"
                },
                "request_id": {
                    "type": "string",
                    "description": "Correlation ID for debugging"
                },
                "details": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object",
                    "description": "Additional error context"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Errors ──────────────────────────────────────────────────",
            "description": "─── Errors ──────────────────────────────────────────────────  Standardized error response across all UPP services."
        }
    }
}