{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$ref": "#/definitions/HealthCheckResponse",
    "definitions": {
        "HealthCheckResponse": {
            "properties": {
                "provider": {
                    "type": "string"
                },
                "healthy": {
                    "type": "boolean"
                },
                "status": {
                    "type": "string",
                    "description": "\"operational\", \"degraded\", \"down\""
                },
                "latency_ms": {
                    "type": "string",
                    "description": "Current latency to provider"
                },
                "checked_at": {
                    "$ref": "#/definitions/upp.v1.Timestamp",
                    "additionalProperties": true
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "Health Check Response"
        },
        "upp.v1.Timestamp": {
            "properties": {
                "seconds": {
                    "type": "string",
                    "description": "Unix epoch seconds"
                },
                "nanos": {
                    "type": "integer",
                    "description": "Sub-second nanoseconds [0, 999999999]"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Temporal ────────────────────────────────────────────────",
            "description": "─── Temporal ────────────────────────────────────────────────  High-precision timestamp for trading events. Always UTC. Nanosecond precision for orderbook/trade events."
        }
    }
}