{
  "name": "@upp/sdk",
  "version": "0.1.0",
  "description": "Universal Prediction Protocol SDK for TypeScript",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./websocket": {
      "types": "./dist/websocket.d.ts",
      "default": "./dist/websocket.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "default": "./dist/mcp.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js && esbuild src/index.ts --bundle --format=esm --outfile=dist/index.esm.js",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "prepublishOnly": "npm run build && npm test",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "prediction-markets",
    "universal-protocol",
    "kalshi",
    "polymarket",
    "opinion-trade",
    "trading-api",
    "typescript",
    "sdk",
    "websocket",
    "mcp"
  ],
  "author": "UPP Labs",
  "license": "MIT",
  "homepage": "https://github.com/upp-labs/sdk-typescript",
  "repository": {
    "type": "git",
    "url": "https://github.com/upp-labs/sdk-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/upp-labs/sdk-typescript/issues"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "ws": "^8.14.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "esbuild": "^0.19.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
