{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$ref": "#/definitions/RateLimitConfig",
    "definitions": {
        "RateLimitConfig": {
            "properties": {
                "rules": {
                    "items": {
                        "$ref": "#/definitions/upp.v1.RateLimitRule"
                    },
                    "type": "array",
                    "description": "Per-endpoint rate limits"
                },
                "tier": {
                    "type": "string",
                    "description": "Tier info  Current tier (e.g. \"standard\", \"premium\")"
                },
                "upgrade_url": {
                    "type": "string",
                    "description": "URL to request higher limits"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Rate Limits ─────────────────────────────────────────────",
            "description": "─── Rate Limits ─────────────────────────────────────────────"
        },
        "upp.v1.RateLimitRule": {
            "properties": {
                "endpoint_pattern": {
                    "type": "string",
                    "description": "Glob pattern, e.g. \"/markets/*\""
                },
                "requests_per_second": {
                    "type": "integer"
                },
                "requests_per_minute": {
                    "type": "integer"
                },
                "burst_limit": {
                    "type": "integer",
                    "description": "Max burst above sustained rate"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "Rate Limit Rule"
        }
    }
}