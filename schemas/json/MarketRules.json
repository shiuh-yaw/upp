{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$ref": "#/definitions/MarketRules",
    "definitions": {
        "MarketRules": {
            "properties": {
                "allowed_order_types": {
                    "items": {
                        "enum": [
                            "ORDER_TYPE_UNSPECIFIED",
                            0,
                            "ORDER_TYPE_LIMIT",
                            1,
                            "ORDER_TYPE_MARKET",
                            2
                        ]
                    },
                    "type": "array",
                    "title": "Order Type",
                    "description": "Order types supported by the market."
                },
                "allowed_tif": {
                    "items": {
                        "enum": [
                            "TIME_IN_FORCE_UNSPECIFIED",
                            0,
                            "TIME_IN_FORCE_GTC",
                            1,
                            "TIME_IN_FORCE_GTD",
                            2,
                            "TIME_IN_FORCE_FOK",
                            3,
                            "TIME_IN_FORCE_IOC",
                            4
                        ]
                    },
                    "type": "array",
                    "title": "Time In Force",
                    "description": "Time-in-force policies."
                },
                "allows_short_selling": {
                    "type": "boolean",
                    "description": "Can sell without holding"
                },
                "allows_partial_fill": {
                    "type": "boolean",
                    "description": "Can orders partially fill"
                },
                "maker_fee_rate": {
                    "type": "string",
                    "description": "Maker fee as decimal, e.g. \"0.00\""
                },
                "taker_fee_rate": {
                    "type": "string",
                    "description": "Taker fee as decimal, e.g. \"0.02\""
                },
                "max_position_size": {
                    "type": "integer",
                    "description": "Position limits  Max contracts per user (0 = unlimited)"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "─── Rules ───────────────────────────────────────────────────",
            "description": "─── Rules ───────────────────────────────────────────────────  Trading rules and constraints for a market."
        }
    }
}