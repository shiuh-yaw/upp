                },
                "time_range": {
                    "$ref": "#/definitions/upp.v1.TimeRange",
                    "additionalProperties": true
                },
                "pagination": {
                    "$ref": "#/definitions/upp.v1.PaginationRequest",
                    "additionalProperties": true
