{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$ref": "#/definitions/GrpcConfig",
    "definitions": {
        "GrpcConfig": {
            "properties": {
                "endpoint": {
                    "type": "string",
                    "description": "e.g. \"api.kalshi.com:443\""
                },
                "tls_required": {
                    "type": "boolean"
                },
                "proto_url": {
                    "type": "string",
                    "description": "URL to .proto files"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "Grpc Config"
        }
    }
}