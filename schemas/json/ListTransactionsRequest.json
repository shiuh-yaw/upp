                        "SETTLEMENT_TRANSACTION_TYPE_DEPOSIT",
                        1,
                        "SETTLEMENT_TRANSACTION_TYPE_WITHDRAWAL",
                        2,
                        "SETTLEMENT_TRANSACTION_TYPE_PAYOUT",
                        3,
                        "SETTLEMENT_TRANSACTION_TYPE_FEE",
                        4,
                        "SETTLEMENT_TRANSACTION_TYPE_REFUND",
                        5
                    ],
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "integer"
                        }
                    ],
                    "title": "Settlement Transaction Type"
                },
                "status": {
                    "enum": [
                        "SETTLEMENT_TRANSACTION_STATUS_UNSPECIFIED",
                        0,
                        "SETTLEMENT_TRANSACTION_STATUS_PENDING",
                        1,
                        "SETTLEMENT_TRANSACTION_STATUS_PROCESSING",
                        2,
                        "SETTLEMENT_TRANSACTION_STATUS_COMPLETED",
                        3,
                        "SETTLEMENT_TRANSACTION_STATUS_FAILED",
                        4,
                        "SETTLEMENT_TRANSACTION_STATUS_CANCELLED",
                        5
                    ],
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "integer"
                        }
                    ],
