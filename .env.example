# UPP Gateway Environment Variables
# Copy this file to .env and fill in actual values for your environment

# ─── Core Configuration ───────────────────────────────────────

# Environment: dev, staging, prod
UPP_ENVIRONMENT=dev

# Server configuration
UPP_HOST=0.0.0.0
UPP_PORT=8080
UPP_GRPC_PORT=50051

# Logging format: json, pretty
UPP_LOG_FORMAT=json

# ─── Provider Credentials ──────────────────────────────────────

# Kalshi API
# Get from: https://kalshi.com/api/settings
UPP_KALSHI_API_KEY_ID=your-kalshi-api-key-id
UPP_KALSHI_PRIVATE_KEY_PATH=/path/to/kalshi/private.key

# Polymarket
# Requires wallet private key for signing transactions
UPP_POLYMARKET_WALLET_KEY=your-polymarket-wallet-key

# Opinion Exchange
# Get from: https://opinionexchange.com/api/settings
UPP_OPINION_API_KEY=your-opinion-api-key

# ─── Cache Configuration ───────────────────────────────────────

# Market data cache TTL (seconds)
UPP_MARKET_CACHE_TTL_SECONDS=300

# Orderbook cache TTL (milliseconds)
UPP_ORDERBOOK_CACHE_TTL_MS=500

# ─── Rate Limiting ─────────────────────────────────────────────

# Light tier (health, metrics, .well-known)
UPP_RATE_LIMIT_LIGHT_BURST=200
UPP_RATE_LIMIT_LIGHT_RPS=100.0

# Standard tier (markets, search, discovery)
UPP_RATE_LIMIT_STANDARD_BURST=50
UPP_RATE_LIMIT_STANDARD_RPS=20.0

# Heavy tier (compute-intensive operations)
UPP_RATE_LIMIT_HEAVY_BURST=20
UPP_RATE_LIMIT_HEAVY_RPS=5.0

# WebSocket tier
UPP_RATE_LIMIT_WS_BURST=10
UPP_RATE_LIMIT_WS_RPS=2.0

# ─── Authentication & Authorization ───────────────────────────

# Require authentication for requests
UPP_AUTH_REQUIRED=false

# JWT secret for signing and verifying tokens (use strong random value)
# Generate with: openssl rand -base64 32
UPP_JWT_SECRET=your-jwt-secret-key-here

# ─── CORS Configuration ────────────────────────────────────────

# Allowed origins (comma-separated or use * for all)
# For multiple origins, set as JSON array in config file or use env var
# UPP_CORS_ORIGINS=https://example.com,https://app.example.com

# ─── Connection Management ────────────────────────────────────

# Maximum concurrent connections
UPP_MAX_CONNECTIONS=10000

# Graceful shutdown timeout (seconds)
UPP_GRACEFUL_SHUTDOWN_TIMEOUT_SECS=30

# ─── TLS/SSL Configuration ────────────────────────────────────

# Path to TLS certificate file (PEM format)
# UPP_TLS_CERT_PATH=/path/to/cert.pem

# Path to TLS private key file (PEM format)
# UPP_TLS_KEY_PATH=/path/to/key.pem

# ─── Redis Configuration ──────────────────────────────────────

# Redis URL for distributed state sharing
# Format: redis://[user:password@]host:port[/db]
# For production, use managed Redis with TLS support
# UPP_REDIS_URL=redis://localhost:6379

# ─── Rust Logging ──────────────────────────────────────────────

# Standard Rust log filter
RUST_LOG=upp_gateway=info,tower_http=debug

# ─── Development Notes ────────────────────────────────────────

# 1. Config file precedence (highest to lowest):
#    - Environment variables (UPP_*)
#    - config/gateway.{environment}.toml
#    - config/gateway.toml
#    - Hardcoded defaults
#
# 2. To use an environment-specific config:
#    - Set UPP_ENVIRONMENT=dev|staging|prod
#    - Place overrides in config/gateway.{env}.toml
#
# 3. Sensitive values (API keys, secrets):
#    - Never commit to version control
#    - Use .env file (gitignored) for local development
#    - Use environment variables or secrets management in CI/CD
#
# 4. For production:
#    - Always use env vars instead of files for secrets
#    - Enable TLS (UPP_TLS_CERT_PATH, UPP_TLS_KEY_PATH)
#    - Set UPP_AUTH_REQUIRED=true
#    - Use managed Redis with TLS
