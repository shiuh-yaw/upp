# UPP Gateway — Environment Configuration
# Copy this to .env and fill in your credentials.

# ── Server ───────────────────────────────────────────────────
UPP_HOST=0.0.0.0
UPP_PORT=8080

# ── Kalshi ───────────────────────────────────────────────────
# Get credentials: https://kalshi.com/settings/api
UPP_KALSHI_API_KEY_ID=
UPP_KALSHI_PRIVATE_KEY_PATH=./keys/kalshi-private.pem

# ── Polymarket ───────────────────────────────────────────────
# Ethereum wallet private key for EIP-712 signing
UPP_POLYMARKET_WALLET_KEY=

# ── Opinion.trade ────────────────────────────────────────────
UPP_OPINION_API_KEY=

# ── Redis (for multi-node deployment) ────────────────────────
UPP_REDIS_URL=redis://localhost:6379

# ── Cache TTLs ───────────────────────────────────────────────
UPP_MARKET_CACHE_TTL_SECONDS=300
UPP_ORDERBOOK_CACHE_TTL_MS=500

# ── Logging ──────────────────────────────────────────────────
RUST_LOG=upp_gateway=info,tower_http=debug
