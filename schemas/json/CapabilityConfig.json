{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$ref": "#/definitions/CapabilityConfig",
    "definitions": {
        "CapabilityConfig": {
            "properties": {
                "supported_market_types": {
                    "items": {
                        "enum": [
                            "MARKET_TYPE_UNSPECIFIED",
                            0,
                            "MARKET_TYPE_BINARY",
                            1,
                            "MARKET_TYPE_CATEGORICAL",
                            2,
                            "MARKET_TYPE_SCALAR",
                            3
                        ]
                    },
                    "type": "array",
                    "title": "─── Market Types ────────────────────────────────────────────",
                    "description": "─── Market Types ────────────────────────────────────────────"
                },
                "categories": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array",
                    "description": "Available categories"
                },
                "supported_order_types": {
                    "items": {
                        "enum": [
                            "ORDER_TYPE_UNSPECIFIED",
                            0,
                            "ORDER_TYPE_LIMIT",
                            1,
                            "ORDER_TYPE_MARKET",
                            2
                        ]
                    },
                    "type": "array",
                    "title": "Order Type",
                    "description": "Order types supported by the market."
                },
                "supported_tif": {
                    "items": {
                        "enum": [
                            "TIME_IN_FORCE_UNSPECIFIED",
                            0,
                            "TIME_IN_FORCE_GTC",
                            1,
                            "TIME_IN_FORCE_GTD",
                            2,
                            "TIME_IN_FORCE_FOK",
                            3,
                            "TIME_IN_FORCE_IOC",
                            4
                        ]
                    },
                    "type": "array",
                    "title": "Time In Force",
                    "description": "Time-in-force policies."
                },
                "supported_oracle_types": {
                    "items": {
                        "enum": [
                            "ORACLE_TYPE_UNSPECIFIED",
                            0,
                            "ORACLE_TYPE_OFFICIAL_DATA",
                            1,
                            "ORACLE_TYPE_FINANCIAL_DATA",
                            2,
                            "ORACLE_TYPE_HUMAN_COMMITTEE",
                            3,
                            "ORACLE_TYPE_AI_ORACLE",
                            4,
                            "ORACLE_TYPE_SMART_CONTRACT",
                            5,
                            "ORACLE_TYPE_DECENTRALIZED",
                            6,
                            "ORACLE_TYPE_PROVIDER_INTERNAL",
                            7
                        ]
                    },
                    "type": "array",
                    "title": "Oracle Type",
                    "description": "Type of resolution oracle."
                },
                "dispute_window_hours": {
                    "type": "integer"
                },
                "supported_currencies": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array",
                    "description": "Settlement capability config"
                },
                "supported_funding_types": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                }
            },
            "additionalProperties": true,
            "type": "object",
            "title": "Capability Config",
            "description": "Capability-specific configuration."
        }
    }
}